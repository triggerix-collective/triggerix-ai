{
  "name": "triggerix-ai",
  "type": "module",
  "version": "0.0.9",
  "description": "AI integration layer for Triggerix — aggregate package re-exporting the suite",
  "license": "MIT",
  "homepage": "https://github.com/triggerix-collective/triggerix-ai#readme",
  "repository": {
    "type": "git",
    "url": "git@github.com:triggerix-collective/triggerix-ai.git",
    "directory": "packages/triggerix-ai"
  },
  "bugs": {
    "url": "https://github.com/triggerix-collective/triggerix-ai/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "stub": "unbuild --stub",
    "build": "unbuild"
  },
  "dependencies": {
    "@triggerix-ai/builder": "workspace:*",
    "@triggerix-ai/component": "workspace:*",
    "@triggerix-ai/fn": "workspace:*",
    "@triggerix-ai/registry": "workspace:*"
  },
  "devDependencies": {
    "unbuild": "^3.6.1"
  }
}
