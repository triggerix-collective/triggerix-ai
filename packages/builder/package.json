{
  "name": "@triggerix-ai/builder",
  "type": "module",
  "version": "0.0.10",
  "description": "Atomic UI builder for Triggerix AI — element-by-element UI construction via LLM tool calls",
  "license": "MIT",
  "homepage": "https://github.com/triggerix-collective/triggerix-ai#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/triggerix-collective/triggerix-ai.git",
    "directory": "packages/builder"
  },
  "bugs": {
    "url": "https://github.com/triggerix-collective/triggerix-ai/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "stub": "unbuild --stub",
    "build": "unbuild"
  },
  "dependencies": {
    "@triggerix-ai/component": "workspace:*",
    "@triggerix-ai/fn": "workspace:*",
    "@triggerix/core": "catalog:triggerix-core",
    "@triggerix/runtime": "catalog:triggerix-core"
  },
  "devDependencies": {
    "unbuild": "catalog:build"
  }
}
