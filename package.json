{
  "name": "@triggerix-ai/monorepo",
  "type": "module",
  "version": "0.0.10",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "description": "AI integration layer for Triggerix — generates tool definitions, dynamic schemas, and system prompts from registered events, actions, and components",
  "license": "MIT",
  "homepage": "https://github.com/triggerix-collective/triggerix-ai#readme",
  "repository": {
    "type": "git",
    "url": "git@github.com:triggerix-collective/triggerix-ai.git"
  },
  "bugs": {
    "url": "https://github.com/triggerix-collective/triggerix-ai/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "stub": "pnpm -r run stub",
    "build": "pnpm -r run build",
    "lint": "eslint --cache",
    "release": "bumpp -r",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:lint",
    "@types/node": "catalog:node",
    "bumpp": "catalog:lint",
    "defu": "catalog:node",
    "eslint": "catalog:lint",
    "esno": "catalog:node",
    "nano-staged": "catalog:lint",
    "simple-git-hooks": "catalog:lint",
    "typescript": "catalog:build",
    "unbuild": "catalog:build",
    "vitest": "catalog:build"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "*": "eslint --cache --fix"
  }
}
